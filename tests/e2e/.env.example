# Copy to tests/e2e/.env and fill in.
# Telegram API creds for the *test user account* (NOT the bot):
TG_API_ID=
TG_API_HASH=
TG_PHONE=+10000000000
TG_SESSION=tgtest_session
TG_TIMEOUT=30
TG_LOG_LEVEL=INFO

# Bot under test — username with or without @
TG_DEFAULT_BOT=@your_bot_under_test
E2E_BOT_USERNAME=@your_bot_under_test

# Optional SOCKS proxy if Telegram is blocked
# TG_PROXY=socks5://127.0.0.1:10808
