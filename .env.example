#! Этот файл необходимо переименовать в .env

# PODCAST SETTINGS
TIMEZONE = "Europe/Moscow"
PODCAST_NAME = "Разговорный жанр"
PODCAST_CITY = "Voronezh"
PODCAST_DISTRICT = "Voronezh region"
PODCAST_COUNTRY = "Russian Federation"
SUPPORT_LINK = "https://podbox.ru/donate/"
PODCAST_LINK = "https://podbox.ru/"


# TELEGRAM LOCAL SERVER SETTINGS
TELEGRAM_SERVER_API_ID = "123456789"
TELEGRAM_SERVER_API_HASH = "AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA"


# TELEGRAM BOT SETTINGS
#! Токен бота, узнать можно у https://t.me/botfather
TELEGRAM_API_TOKEN = "1234567890:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA"
SKIP_UPDATES = "True"
#! Username публичной группы/канала для форварда анонсов (можно без @)
FORWARD_CHAT_USERNAME = "@my_group"


# FTP SETTINGS
FTP_SERVER = "test.io"
FTP_LOGIN = "user"
FTP_PASSWORD = "password"


# WORDPRESS
# Just to main page
WP_URL = "https://wordpress_site.org"
WP_LOGIN = "user"
WP_PASSWORD = "password"
WP_APP_PASSWORD = "app_password"


# BOOSTY
# Slug блога: boosty.to/<BOOSTY_BLOG>
BOOSTY_BLOG = "my_blog"
# auth.json экспортируется один раз из браузерной сессии (access_token /
# refresh_token / device_id). Путь внутри контейнера (volume boosty_data).
BOOSTY_AUTH_FILE = "/app/data/boosty_auth.json"
# Числовой id платного уровня подписки, к которому привязывается пост.
BOOSTY_SUBSCRIPTION_LEVEL_ID = "407063"
# Цена поста (pay-per-post), в рублях.
BOOSTY_PRICE = "10"
# Обложка-тизер (лежит на томе files). Опционально — есть дефолт.
# BOOSTY_COVER_PATH = "/app/files/boosty_pscover.png"


# LOGGER SETTINGS
# "TRACE", "DEBUG", "INFO", "SUCCESS", "WARNING", "ERROR", "CRITICAL"
LOG_LEVEL = "INFO"


# default tg_server is official api server
# it can be for example:
#TG_SERVER = 'http://api:8081'
LOCAL = "False"


# default parse_mode is None
# it can be "html" or "markdown"
PARSE_MODE = "html"


# example: socks5://127.0.0.1:1080
# PROXY

# example:
# from aiohttp import BasicAuth
# PROXY_AUTH = BasicAuth(
#     USERNAME,
#     PASSWORD
# )
# PROXY_AUTH

# if True, then bot will support work with DATABASE
DATABASE = "False"


# example:
# MYSQL = mysql+pymysql://USER:PASS@HOST:PORT/DB?charset=utf8mb4
# SQLITE = sqlite:///database.sqlite
DATABASE_URL = "sqlite:///database.sqlite"


# Пароль для встроенного redis (docker-compose). Обязательно задай —
# bot/redis/redis_exporter все берут его из этой переменной.
REDIS_PASSWORD = "change_me"

# REDIS_URL ВРУЧНУЮ выставлять не надо: в docker-compose он собирается
# автоматом из REDIS_PASSWORD как redis://:${REDIS_PASSWORD}@redis:6379/0.
# Раскомментируй только если запускаешь бота не в docker'е и redis
# где-то снаружи. Если REDIS_URL не задан — bot и APScheduler используют
# memory storage (FSM не переживает рестарт).
# REDIS_URL = "redis://:password@host:6379/0"


KEYBOARDS_DIR = "keyboards"
HANDLERS_DIR = "handlers"
MODELS_DIR = "models"


# if REDIS_URL is set, APSCHEDULER uses redis to store jobs
ENABLE_APSCHEDULER = "False"


ADMINS = ["admin"]
ADMINS_ID = [0]

HANDLERS = ["middlewares", "start", "admin_panel"]

KEYBOARDS = ["podcast_handler", "admin"]

LANGUAGES = ["ru", "en"]

# FILES
COVER_RZ_NAME = "cover.jpg"
COVER_PS_NAME = "pscover.jpg"
PODCAST = "podcast.mp3"
FILES_PATH = "files"
LOGS_PATH = "logs"
WP_COOKIE_FILENAME = "cookie.pkl"

# KAFKA SETTINGS
KAFKA_SERVER = "kafka:9092"
SCHEMA_REGISTRY_URL = "http://schema-registry:8081"